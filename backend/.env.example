# ─────────────────────────────────────────────
# Django Core
# ─────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────
# Database — Neon PostgreSQL
# Get this from your Neon dashboard → Connection string
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/dbname?sslmode=require

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─────────────────────────────────────────────
# URL Safety — Google Safe Browsing API
# Get from: https://console.cloud.google.com
# ─────────────────────────────────────────────
GOOGLE_SAFE_BROWSING_API_KEY=your-google-safe-browsing-api-key

# ─────────────────────────────────────────────
# AI Integration — Google Gemini (Optional)
# Get your key: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-from-ai-studio
GEMINI_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────
# GeoIP2 (Optional — for country/city analytics)
# 1. Register free at: https://www.maxmind.com/en/geolite2/signup
# 2. Download GeoLite2-City.mmdb from your MaxMind account
# 3. Set the absolute path to the .mmdb file below
# Without this, no country/city data will be recorded in analytics
# ─────────────────────────────────────────────
GEOIP2_DATABASE_PATH=

# ─────────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────────
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Media & Storage
# ─────────────────────────────────────────────
QR_CODE_STORAGE_PATH=media/qr_codes/

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
MAX_URLS_PER_HOUR=50
MAX_URLS_PER_DAY=200
